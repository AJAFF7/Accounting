@inherits SoftMaxComponent
<SoftMaxDialog>
    <Content>
        <MudForm @ref=Form Model=Model Class=my-3>
            <MudGrid Spacing=2>
                <SoftMaxGridItem md="5">
                    <SoftMaxTextBox @bind-Value=Model.Name Label="Name" Required=true RequiredError=@null />
                </SoftMaxGridItem>
                <SoftMaxGridItem md="5">
                    <MudAutocomplete @bind-Value=Model.Type
                                     Label=@Localizer["Lookup Type"].Value
                                     Required=true
                                     RequiredError=@null
                                     Variant="Variant.Outlined"
                                     Margin="Margin.Dense"
                                     Dense="true"
                                     Strict="false"
                                     CoerceValue
                                     CoerceText
                                     SearchFunc="SearchTypes"
                                     FullWidth="true"
                                     Clearable="true" />
                </SoftMaxGridItem>
                <SoftMaxGridItem md="2">
                    <SoftMaxNumericTextBox @bind-Value=Model.Sort Label="Sort" />
                </SoftMaxGridItem>

                <SoftMaxGridItem md="6">
                    <MudPaper Class="pa-4 mt-2 h-100" Outlined>
                        <MudText Typo="Typo.h6" Class="mb-3">@Localizer["Localized Names"].Value:</MudText>

                        <MudGrid Class="mb-3" Spacing="1">
                            <SoftMaxGridItem md="4">
                                <MudSelect @bind-Value="@newLocale"
                                           Label="Language"
                                           Variant="Variant.Outlined"
                                           Dense="true"
                                           Margin="Margin.Dense">
                                    @if (availableLocales != null)
                                    {
                                        @foreach (var locale in availableLocales.Where(l => !Model.LocalizedNames.ContainsKey(l.Value)))
                                        {
                                            <MudSelectItem Value="@locale.Value">@locale.Text</MudSelectItem>
                                        }
                                    }
                                </MudSelect>
                            </SoftMaxGridItem>
                            <SoftMaxGridItem FillContent>
                                <MudTextField @bind-Value="@newLocalizedName"
                                              Label="Localized Name"
                                              Variant="Variant.Outlined"
                                              Margin="Margin.Dense"
                                              Immediate />
                            </SoftMaxGridItem>
                            <SoftMaxGridItem AutoContent Class="d-flex align-center">
                                <MudIconButton OnClick="AddLocalizedName"
                                               Disabled="@(string.IsNullOrEmpty(newLocale) || string.IsNullOrEmpty(newLocalizedName))"
                                               Icon="@Icon.Add"
                                               Color="Color.Primary"
                                               Variant="Filled"
                                               Class="rounded-1 mt-1"
                                               DropShadow=false
                                               Size="Size.Large" />
                            </SoftMaxGridItem>
                        </MudGrid>

                        @if (Model.LocalizedNames?.Any() == true)
                        {
                            <MudText Typo="Typo.subtitle2" Class="mb-2">@Localizer["Current Translations"].Value:</MudText>
                            @foreach (var localizedName in Model.LocalizedNames.ToList())
                            {
                                var currentValue = localizedName.Value;
                                <MudGrid Class="mb-2" Spacing="1">
                                    <SoftMaxGridItem md="4">
                                        <MudTextField Value=@GetLocaleName(localizedName.Key)
                                                      ReadOnly="true"
                                                      Variant="Variant.Outlined"
                                                      Margin="Margin.Dense" />
                                    </SoftMaxGridItem>
                                    <SoftMaxGridItem FillContent>
                                        <MudTextField Value="@currentValue"
                                                      ValueChanged="@((string value) => UpdateLocalizedName(localizedName.Key, value))"
                                                      Variant="Variant.Outlined"
                                                      Margin="Margin.Dense" />
                                    </SoftMaxGridItem>
                                    <SoftMaxGridItem AutoContent Class="d-flex align-center">
                                        <MudIconButton OnClick="@(() => RemoveLocalizedName(localizedName.Key))"
                                                       Icon="@Icon.Delete"
                                                       Color="Color.Error"
                                                       Variant="Filled"
                                                       DropShadow=false
                                                       Size="Size.Large" />
                                    </SoftMaxGridItem>
                                </MudGrid>
                            }
                        }
                    </MudPaper>
                </SoftMaxGridItem>

                <SoftMaxGridItem md="6">
                    <MudPaper Class="pa-4 mt-2 h-100" Outlined>
                        <MudText Typo="Typo.h6" Class="mb-3">Fields</MudText>

                        <MudGrid Class="mb-3" Spacing="1">
                            <SoftMaxGridItem md="4">
                                <MudTextField @bind-Value="@newFieldKey"
                                              Label="Field Key"
                                              Variant="Variant.Outlined"
                                              Margin="Margin.Dense"
                                              Immediate />
                            </SoftMaxGridItem>
                            <SoftMaxGridItem FillContent>
                                <MudTextField @bind-Value="@newFieldValue"
                                              Label="Field Value"
                                              Variant="Variant.Outlined"
                                              Margin="Margin.Dense"
                                              Immediate />
                            </SoftMaxGridItem>
                            <SoftMaxGridItem AutoContent Class="d-flex align-center">
                                <MudIconButton OnClick="AddField"
                                               Disabled="@(string.IsNullOrEmpty(newFieldKey))"
                                               Icon="@Icon.Add"
                                               Color="Color.Primary"
                                               Variant="Filled"
                                               Class="rounded-1 mt-1"
                                               DropShadow=false
                                               Size="Size.Large" />
                            </SoftMaxGridItem>
                        </MudGrid>

                        @if (Model.Fields?.Any() == true)
                        {
                            <MudText Typo="Typo.subtitle2" Class="mb-2">Current Fields:</MudText>
                            @foreach (var field in Model.Fields.ToList())
                            {
                                <MudGrid Class="mb-2" Spacing="1">
                                    <SoftMaxGridItem md="4">
                                        <MudTextField ReadOnly
                                                      Value="@field.Key"
                                                      Variant="Variant.Outlined"
                                                      Margin="Margin.Dense" />
                                    </SoftMaxGridItem>
                                    <SoftMaxGridItem FillContent>
                                        <MudTextField Value="@field.Value"
                                                      ValueChanged="@((string value) => UpdateField(field.Key, value))"
                                                      Variant="Variant.Outlined"
                                                      Margin="Margin.Dense" />
                                    </SoftMaxGridItem>
                                    <SoftMaxGridItem AutoContent Class="d-flex align-center">
                                        <MudIconButton OnClick="@(() => RemoveField(field.Key))"
                                                       Icon="@Icon.Delete"
                                                       Color="Color.Error"
                                                       Variant="Filled"
                                                       Class="rounded-1"
                                                       DropShadow=false
                                                       Size="Size.Large" />
                                    </SoftMaxGridItem>
                                </MudGrid>
                            }
                        }
                    </MudPaper>
                </SoftMaxGridItem>
            </MudGrid>
        </MudForm>
    </Content>
    <Actions>
        <SoftMaxButton Text="Close"
                       Disabled=@Repository.ModelProcessing
                       OnClick=Dialog.Cancel
                       EndIcon=@Icon.Close
                       DropShadow=false
                       Size="Medium" />
        <MudButtonGroup Color=Success
                        Variant=Filled
                        Size=Medium
                        DropShadow=false
                        OverrideStyles=false>
            <SoftMaxButton Text="Save & New"
                           Disabled=Repository.ModelProcessing
                           OnClick=@(async e => await Repository.SaveAsync(Model, Form, DataGrid, Dialog, false))
                           StartIcon=@Icon.Save
                           DropShadow=false
                           Color="Success"
                           Size="Medium" />
            <MudMenu Dense
                     Disabled=Repository.ModelProcessing
                     Icon="@Icon.ArrowDropDown"
                     Variant="Filled"
                     Color="Success"
                     Style="align-self: auto;">
                <MudMenuItem OnClick=@(async e => await Repository.SaveAsync(Model, Form, DataGrid, Dialog, true))>@Localizer["Save & Close"].Value</MudMenuItem>
                <MudMenuItem OnClick=@(async e => await Repository.SaveAsync(Model, Form, DataGrid, Dialog, null))>@Localizer["Save"].Value</MudMenuItem>
            </MudMenu>
        </MudButtonGroup>
    </Actions>
</SoftMaxDialog>

@code {
    [CascadingParameter] private IMudDialogInstance Dialog { get; set; }
    [Parameter] public LookupRepository Repository { get; set; }
    [Parameter] public LookupRepository.Model Model { get; set; } = new();
    [Parameter] public SoftMaxGrid<LookupRepository.Model, Lookups> DataGrid { get; set; }
    public MudForm Form { get; set; }

    private string newLocale = "";
    private string newLocalizedName = "";
    private List<DataItem<string>> availableLocales;
    private List<string> availableTypes;

    private string newFieldKey = "";
    private string newFieldValue = "";

    protected override async Task OnInitializedAsync()
    {
        availableLocales = await Repository.GetAvailableLocalesAsync();
        availableTypes = (await Repository.GetAvailableTypesAsync()).Select(a => a.Text).ToList();
    }

    private void AddLocalizedName()
    {
        if (!string.IsNullOrEmpty(newLocale) && !string.IsNullOrEmpty(newLocalizedName))
        {
            Model.SetLocalizedName(newLocale, newLocalizedName);
            newLocale = "";
            newLocalizedName = "";
            StateHasChanged();
        }
    }

    private void UpdateLocalizedName(string locale, string value) => Model.SetLocalizedName(locale, value);

    private void RemoveLocalizedName(string locale)
    {
        Model.LocalizedNames.Remove(locale);
        StateHasChanged();
    }

    private string GetLocaleName(string localeCode) => availableLocales?.FirstOrDefault(l => l.Value == localeCode)?.Text ?? localeCode;


    private void AddField()
    {
        if (!string.IsNullOrEmpty(newFieldKey) && !string.IsNullOrEmpty(newFieldValue))
        {
            Model.SetField(newFieldKey, newFieldValue);
            newFieldKey = "";
            newFieldValue = "";
            StateHasChanged();
        }
    }

    private void UpdateField(string key, string value) => Model.SetField(key, value);

    private void RemoveField(string key)
    {
        Model.Fields.Remove(key);
        StateHasChanged();
    }

    private async Task<IEnumerable<string>> SearchTypes(string value, CancellationToken token)
    {
        await Task.Delay(1, token);

        if (string.IsNullOrEmpty(value))
            return availableTypes;

        return availableTypes.Where(x => x.Contains(value, StringComparison.InvariantCultureIgnoreCase));
    }
}